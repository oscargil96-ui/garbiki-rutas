    ]
  },
  SABADO:{
    notes:"🚚 Wilson: entrega y recogida en Zenit Logroño.",
    WILSON:[{name:"ZENIT LOGROÑO",zone:"Avda. de Mendavia, Logroño",er:"E/R"}],
    JUAN:[]
  }
};

// Load or init route data from localStorage
let routeData = JSON.parse(localStorage.getItem("garbiki_routes")||"null") || JSON.parse(JSON.stringify(DEFAULT_DATA));

// Session state (resets on reload — marks/counts per day)
const state = {};
DAYS.forEach(d=>{
  state[d]={};
  ["WILSON","JUAN"].forEach(r=>{
    state[d][r]=(routeData[d][r]||[]).map(()=>({done:false,sacos:0,carros:0}));
  });
});

function syncState(){
  DAYS.forEach(d=>{
    ["WILSON","JUAN"].forEach(r=>{
      const cur = state[d][r]||[];
      const needed = (routeData[d][r]||[]).length;
      while(cur.length < needed) cur.push({done:false,sacos:0,carros:0});
      state[d][r] = cur.slice(0,needed);
    });
  });
}

function saveRoutes(){ localStorage.setItem("garbiki_routes",JSON.stringify(routeData)); }

const todayIdx = [1,2,3,4,5,6].indexOf(new Date().getDay());
let curDay = DAYS[todayIdx>=0?todayIdx:0]||"LUNES";
let curRep = "WILSON";
let adminLoggedIn = false;
let adminDay = curDay, adminRep = "WILSON";

function opts(val,max){
  let h='<option value="0">— 0</option>';
  for(let i=1;i<=max;i++) h+=`<option value="${i}"${val==i?" selected":""}>${i}</option>`;
  return h;
}

function render(){
  // day tabs
  const dayEl=document.getElementById("dayTabs");
  dayEl.innerHTML=DAYS.map(d=>{
    const stops=routeData[d][curRep]||[];
    const st=state[d][curRep]||[];
    const allDone=stops.length>0&&st.filter(s=>s.done).length===stops.length;
    return`<button class="day-tab${d===curDay?" active":""}" onclick="setDay('${d}')">${DAY_LABELS[d]}${allDone?" ✓":""}</button>`;
  }).join('');

  // rep tabs
  const repsAvail=["WILSON","JUAN"].filter(r=>(routeData[curDay][r]||[]).length>0);
  if(!repsAvail.includes(curRep)) curRep=repsAvail[0]||"WILSON";
  const repEl=document.getElementById("repTabs");
  repEl.innerHTML=repsAvail.map(r=>
    `<button class="rep-tab${r===curRep?" active "+r.toLowerCase():""}" onclick="setRep('${r}')">${r==="WILSON"?"🚚 Wilson":"🚐 Juan"}</button>`
  ).join('');

  // summary
  const stops=routeData[curDay][curRep]||[];
  const st=state[curDay][curRep]||[];
  const done=st.filter(s=>s.done).length;
  const sacos=st.reduce((a,s)=>a+s.sacos,0);
  const carros=st.reduce((a,s)=>a+s.carros,0);
  const pct=stops.length?Math.round(done/stops.length*100):0;
  document.getElementById("summaryBar").innerHTML=`
    <div class="summary-card"><div class="num">${done}/${stops.length}</div><div class="lbl">Paradas ${pct}%</div></div>
    <div class="summary-card"><div class="num">${sacos}</div><div class="lbl">🧺 Sacos</div></div>
    <div class="summary-card"><div class="num">${carros}</div><div class="lbl">🛒 Carros</div></div>
  `;

  // notes
  const notesEl=document.getElementById("notesBox");
  const n=routeData[curDay].notes;
  if(n){notesEl.textContent=n;notesEl.classList.add("visible");}
  else notesEl.classList.remove("visible");

  // stops
  const listEl=document.getElementById("stopList");
  if(!stops.length){
    listEl.innerHTML=`<div class="empty-msg"><span style="font-size:40px">😴</span><br>Sin ruta este día</div>`;
    return;
  }
  listEl.innerHTML=stops.map((s,i)=>{
    const item=st[i]||{done:false,sacos:0,carros:0};
    return`<div class="stop-card${item.done?" done":""}" id="sc${i}">
      <div class="stop-header">
        <div class="stop-num">${item.done?"✓":i+1}</div>
        <div class="stop-info">
          <div class="stop-name">${s.name}</div>
          <div class="stop-zone">📍 ${s.zone}</div>
        </div>
        ${s.er?`<span class="er-badge">${s.er}</span>`:""}
      </div>
      <div class="stop-inputs">
        <div class="input-group"><label>🧺 Sacos recogidos</label><select onchange="upd(${i},'sacos',this.value)">${opts(item.sacos,30)}</select></div>
        <div class="input-group"><label>🛒 Carros recogidos</label><select onchange="upd(${i},'carros',this.value)">${opts(item.carros,20)}</select></div>
      </div>
      <button class="check-btn" onclick="toggle(${i})">${item.done?"✅ Completado — pulsa para desmarcar":"☑️ Marcar como entregado"}</button>
    </div>`;
  }).join('');
}

function setDay(d){curDay=d;render();}
function setRep(r){curRep=r;render();}
function toggle(i){state[curDay][curRep][i].done=!state[curDay][curRep][i].done;render();}
function upd(i,f,v){
  state[curDay][curRep][i][f]=parseInt(v);
  const st=state[curDay][curRep];
  const stops=routeData[curDay][curRep]||[];
  const done=st.filter(s=>s.done).length;
  const sacos=st.reduce((a,s)=>a+s.sacos,0);
  const carros=st.reduce((a,s)=>a+s.carros,0);
  const pct=stops.length?Math.round(done/stops.length*100):0;
  document.getElementById("summaryBar").innerHTML=`
    <div class="summary-card"><div class="num">${done}/${stops.length}</div><div class="lbl">Paradas ${pct}%</div></div>
    <div class="summary-card"><div class="num">${sacos}</div><div class="lbl">🧺 Sacos</div></div>
    <div class="summary-card"><div class="num">${carros}</div><div class="lbl">🛒 Carros</div></div>
  `;
}

/* ---- ADMIN ---- */
function openAdmin(){
  document.getElementById("adminOverlay").classList.add("open");
  if(adminLoggedIn) renderAdminPanel();
  else renderLogin();
}
function closeAdmin(){document.getElementById("adminOverlay").classList.remove("open");}

function renderLogin(){
  document.getElementById("adminTitle").textContent="⚙️ Administración";
  document.getElementById("adminBody").innerHTML=`
    <div class="login-box">
      <p>Introduce la contraseña para acceder al panel de administración.</p>
      <div class="login-err" id="loginErr">Contraseña incorrecta</div>
      <input type="password" id="passInput" placeholder="Contraseña" onkeydown="if(event.key==='Enter')doLogin()">
      <button class="btn-primary" onclick="doLogin()">Entrar</button>
    </div>`;
  setTimeout(()=>document.getElementById("passInput").focus(),100);
}

function doLogin(){
  const v=document.getElementById("passInput").value;
  if(v===PASS){adminLoggedIn=true;renderAdminPanel();}
  else{document.getElementById("loginErr").style.display="block";}
}

function renderAdminPanel(){
  adminDay=adminDay||curDay;
  adminRep=adminRep||"WILSON";
  document.getElementById("adminTitle").textContent="⚙️ Gestión de rutas";
  const reps=["WILSON","JUAN"];
  const dayOpts=DAYS.map(d=>`<option value="${d}"${d===adminDay?" selected":""}>${d}</option>`).join('');
  const repOpts=reps.map(r=>`<option value="${r}"${r===adminRep?" selected":""}>${r}</option>`).join('');
  const clients=routeData[adminDay][adminRep]||[];
  const clientList=clients.length
    ? clients.map((c,i)=>`
        <div class="client-item">
          <div class="client-item-info">
            <div class="client-item-name">${c.name}${c.er?` <span class="er-badge">${c.er}</span>`:""}</div>
            <div class="client-item-zone">📍 ${c.zone}</div>
          </div>
          <button class="del-btn" onclick="deleteClient(${i})" title="Eliminar">✕</button>
        </div>`).join('')
    : `<div class="empty-clients">Sin clientes este día</div>`;

  const noteVal=(routeData[adminDay].notes||"").replace(/"/g,"&quot;");

  document.getElementById("adminBody").innerHTML=`
    <div class="admin-section">
      <h3>📋 Seleccionar día y repartidor</h3>
      <div class="selector-row">
        <select class="form-select" onchange="adminDay=this.value;renderAdminPanel()">${dayOpts}</select>
        <select class="form-select" onchange="adminRep=this.value;renderAdminPanel()">${repOpts}</select>
      </div>
    </div>

    <div class="admin-section">
      <h3>➕ Añadir cliente</h3>
      <input class="form-input" id="newName" placeholder="Nombre del cliente" autocomplete="off">
      <input class="form-input" id="newZone" placeholder="Zona o dirección" autocomplete="off">
      <select class="form-select" id="newEr">
        <option value="">Sin tipo</option>
        <option value="E">E — Solo entrega</option>
        <option value="R">R — Solo recogida</option>
        <option value="E/R">E/R — Entrega y recogida</option>
      </select>
      <button class="add-btn" onclick="addClient()">➕ Añadir cliente</button>
      <div class="success-msg" id="addOk">✅ Cliente añadido correctamente</div>
    </div>

    <div class="admin-section">
      <h3>👥 Clientes en ruta (${clients.length})</h3>
      ${clientList}
    </div>

    <div class="admin-section">
      <h3>📌 Nota del día</h3>
      <textarea class="notes-edit-area" id="notesEdit">${routeData[adminDay].notes||""}</textarea>
      <button class="save-notes-btn" onclick="saveNotes()">💾 Guardar nota</button>
      <div class="success-msg" id="notesOk">✅ Nota guardada</div>
    </div>

    <div class="admin-section">
      <button class="btn-primary btn-danger" onclick="if(confirm('¿Cerrar sesión?')){adminLoggedIn=false;closeAdmin();}">🔒 Cerrar sesión</button>
    </div>
  `;
}

function addClient(){
  const name=document.getElementById("newName").value.trim().toUpperCase();
  const zone=document.getElementById("newZone").value.trim();
  const er=document.getElementById("newEr").value;
  if(!name){document.getElementById("newName").focus();return;}
  if(!routeData[adminDay][adminRep]) routeData[adminDay][adminRep]=[];
  routeData[adminDay][adminRep].push({name,zone:zone||"—",er});
  syncState();
  saveRoutes();
  const ok=document.getElementById("addOk");
  ok.classList.add("show");
  setTimeout(()=>ok.classList.remove("show"),2000);
  document.getElementById("newName").value="";
  document.getElementById("newZone").value="";
  document.getElementById("newEr").value="";
  renderAdminPanel();
  render();
}

function deleteClient(idx){
  const c=routeData[adminDay][adminRep][idx];
  if(!confirm(`¿Eliminar "${c.name}" de la ruta del ${adminDay} (${adminRep})?`)) return;
  routeData[adminDay][adminRep].splice(idx,1);
  syncState();
  saveRoutes();
  renderAdminPanel();
  render();
}

function saveNotes(){
  routeData[adminDay].notes=document.getElementById("notesEdit").value.trim();
  saveRoutes();
  const ok=document.getElementById("notesOk");
  ok.classList.add("show");
  setTimeout(()=>ok.classList.remove("show"),2000);
  render();
}

render();
</script>
</body>
</html>
